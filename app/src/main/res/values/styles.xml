<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ViewModelLiveDataDemoEnrichi" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/accent_teal</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="CounterButton">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:minHeight">54dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="CounterButton.Primary" parent="CounterButton">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/button_text</item>
    </style>

    <style name="CounterButton.Secondary" parent="CounterButton">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/button_text</item>
    </style>

    <style name="CounterButton.Reset" parent="CounterButton">
        <item name="android:background">@drawable/bg_button_reset</item>
        <item name="android:textColor">@color/button_reset_text</item>
    </style>
</resources>
